{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "prompt_append": "사용자에게 항상 한국어로 응답해주세요."
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  }
}
